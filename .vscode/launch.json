{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "File Desk: Backend",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "module": "backend.http_main",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": false,
      "presentation": {
        "group": "file-desk",
        "order": 1
      }
    },
    {
      "name": "File Desk: MCP App Preview",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "program": "${workspaceFolder}/.venv/bin/fastmcp",
      "args": ["dev", "apps", "fastmcp_dev.py:server", "--mcp-port", "8001", "--dev-port", "8080"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": false,
      "presentation": {
        "group": "file-desk",
        "order": 2
      }
    }
  ]
}
